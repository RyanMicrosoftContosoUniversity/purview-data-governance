TENANT_ID=YOUR_TENANT_ID
CLIENT_ID=YOUR_CLIENT_ID
# Generate a client secret and set it in a secure store; do NOT commit secrets to git.
CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
# Use either a connection string or Managed Identity; keep secrets out of repo.
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=REPLACE_WITH_ACCOUNT_KEY;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=fabric-audit-logs

# Notes:
# - Copy this file to `scripts/fabric_audit_env.env` locally if needed, or set env vars in CI/Key Vault.
# - After rotating credentials, update your environment and remove any local copies with secrets.